{{> menu id="dashboard"}}

<section class="ui left aligned middle aligned segment">

  <form class="ui stacked segment form" action="/dashboard/addplaylist" method="POST">
    <div class="two fields">
      <div class="field">
        <label>Title</label>
        <input placeholder="Title" type="text" name="title" required>
      </div>
      <div class="field">
        <label>Rating</label>
        <input placeholder="Rating" type="number" name="rating" min="1" max="5" required>
      </div>
    </div>
    <button class="ui blue submit button">Add Playlist</button>
  </form>
  
  {{> listplaylists}}

</section>

